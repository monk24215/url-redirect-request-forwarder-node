  },
  "files": [
    "src/",
    "index.js",
    "sql/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test 'test/*.test.js'"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "http",
    "proxy",
    "forwarder",
    "webhook",
    "fetch",
    "retry",
    "redirect"
  ],
